# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/
.ruff_cache/
.mypy_cache/

# Tooling artifacts
htmlcov/
.coverage
.coverage.*

# Virtual environments
venv/
.venv/
env/
.env/
# Carve-outs for project-tracked paths that match the venv-style ``env/``
# rule above. Without these, ``src/catan_rl/env/`` and ``tests/unit/env/``
# get silently dropped from new commits (the wildcard matches both venvs
# *and* the project's RL env package).
!src/catan_rl/env/
!tests/unit/env/

# Training artifacts — large, generated, not committed
checkpoints/
runs/
logs/

# Old SB3 / zip model artifacts
models/*.zip
models/hof/
*.zip

# Editor
.DS_Store
.cursor/
.vscode/
*.swp
*.swo

# Claude Code — personal/local only
.claude/settings.local.json
.claude/.session-data/
.claude/transcripts/

# Jupyter
.ipynb_checkpoints/

# Test / coverage
.pytest_cache/
.coverage
htmlcov/

# Rust build artifacts (workspace target + maturin-built .so)
target/

# Maturin compiles the Rust extension into src/catan_engine/ during
# editable installs (``pip install -e .`` or ``maturin develop``).
# The .so is the build artifact; the package marker __init__.py is
# the tracked source.
src/catan_engine/*.so
src/catan_engine/*.dylib
src/catan_engine/*.pyd

# Per-dev-box cargo config — templated from .cargo/config.toml.example
# by ``make rust-setup``. Each contributor's miniconda/homebrew
# libpython path goes in here; never committed.
.cargo/config.toml
